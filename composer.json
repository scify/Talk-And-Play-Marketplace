{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2.0",
        "ext-json": "*",
        "ext-libxml": "*",
        "ext-simplexml": "*",
        "ext-zip": "*",
        "doctrine/dbal": "^3.10",
        "guzzlehttp/guzzle": "^7.14.0",
        "laravel/fortify": "^1.37",
        "laravel/framework": "^12.61",
        "laravel/tinker": "^2.11",
        "scify/laravel-cookie-guard": "^4.1",
        "sentry/sentry-laravel": "^4.26.0",
        "spatie/laravel-sitemap": "^7.4",
        "symfony/http-client": "^6.4",
        "symfony/mailgun-mailer": "^6.4"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.16",
        "fakerphp/faker": "^1.9.1",
        "laravel/pint": "^1.29",
        "laravel/sail": "^1.63.0",
        "mockery/mockery": "^1.4.2",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest-plugin-laravel": "^3.1",
        "spatie/laravel-ignition": "^2.12"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        },
        "files": [
            "app/Utils/UrlHelpers.php"
        ]
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true,
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
